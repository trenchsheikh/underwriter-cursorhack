# Underwriter backend environment example.
# Copy this file to backend/.env (or .env at the repo root) and fill in values.
# All variables are read by app/core/config.py via pydantic-settings.

# ---- Runtime ----
APP_ENV=development            # development | staging | production
APP_NAME=underwriter
DEBUG=true                     # set to false in production
HOST=0.0.0.0
PORT=8000

# ---- Database ----
# Defaults to a local SQLite file for easy bootstrap.
DATABASE_URL=sqlite:///./underwriter.db
# Postgres example (used by docker-compose):
# DATABASE_URL=postgresql+psycopg2://underwriter:underwriter@localhost:5432/underwriter

# ---- JWT auth ----
# IMPORTANT: override JWT_SECRET in any non-development environment.
JWT_SECRET=change-me-in-prod-please
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# ---- Optional: LLM-assisted decision narrative ----
# The rule-based engine works fully without these. When OPENAI_API_KEY is set,
# a short underwriter-style note is appended to the decision narrative.
# The LLM can NEVER change the outcome, approved amount, or APR.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- CORS ----
# Comma-separated list of allowed origins. Use specific origins in production.
CORS_ORIGINS=*

# ---- Bootstrap admin ----
# Created on first start only if there are no users in the database.
# Override these before deploying.
BOOTSTRAP_ADMIN_EMAIL=admin@underwriter.example
BOOTSTRAP_ADMIN_PASSWORD=admin12345

# ---- File uploads ----
# Directory where uploaded supporting documents are stored on disk.
UPLOAD_DIR=uploads
