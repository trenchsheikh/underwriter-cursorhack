# UnderWriter backend — environment variables.
# Copy to backend/.env and fill in values you actually have.
# Every external API has a fixture fallback, so all keys are OPTIONAL
# in the demo path (see DEMO_FORCE_FIXTURES below).

# ---- Cursor TypeScript SDK (preferred for narrative LLM calls) ----
# When set, the memo editorial summary and amendment rationale are produced
# by a one-shot @cursor/sdk Agent.prompt() run, using the same Cursor agent
# runtime that powers the IDE / CLI / Cloud Agents.
#   https://cursor.com/blog/typescript-sdk
#   https://cursor.com/docs/sdk/typescript
# Get a key from https://cursor.com/dashboard/integrations.
CURSOR_API_KEY=
# Optional. Cursor model id, e.g. "composer-2" (default), "auto".
CURSOR_MODEL=composer-2
# Set to "true" to skip the SDK path even if CURSOR_API_KEY is present.
UNDERWRITER_DISABLE_CURSOR_SDK=false

# ---- OpenAI fallback (used only when CURSOR_API_KEY is empty) ----
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MEMO_MODEL=gpt-4o-mini
OPENAI_PARSE_MODEL=gpt-4o-mini

# ---- Specter ----
SPECTER_API_KEY=
SPECTER_API_BASE=
SPECTER_MCP_URL=

# ---- Companies House ----
COMPANIES_HOUSE_API_KEY=

# ---- OpenSanctions (key optional for higher rate limits) ----
OPENSANCTIONS_API_KEY=

# ---- WHOIS ----
# Set true to attempt live WHOIS instead of fixtures.
WHOIS_LIVE=false

# ---- Demo behaviour ----
# When true, all sources skip live calls and serve from fixtures.
# This is the on-stage panic button if the network goes sideways.
DEMO_FORCE_FIXTURES=false

# When set, amendments may open a real PR (not implemented in demo path).
DEMO_GITHUB_REPO=
GITHUB_TOKEN=

# ---- App ----
NODE_ENV=development
PORT=3001
