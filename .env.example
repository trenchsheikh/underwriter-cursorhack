APP_ENV=development
APP_NAME=underwriter
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Database (defaults to local SQLite for easy bootstrap)
DATABASE_URL=sqlite:///./underwriter.db
# DATABASE_URL=postgresql+psycopg2://underwriter:underwriter@localhost:5432/underwriter

# JWT auth
JWT_SECRET=change-me-in-prod-please
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# Optional LLM-assisted narrative explanation (rule-based scoring works without it).
# Uses any OpenAI-compatible chat-completions endpoint. Set CURSOR_API_KEY to a
# Cursor API key (https://cursor.com) or any OpenAI-compatible provider's key.
CURSOR_API_KEY=
CURSOR_API_BASE_URL=https://api.openai.com/v1
CURSOR_MODEL=gpt-4o-mini

# CORS (comma-separated)
CORS_ORIGINS=*

# Bootstrap admin (created on first start if no users exist)
BOOTSTRAP_ADMIN_EMAIL=admin@underwriter.example
BOOTSTRAP_ADMIN_PASSWORD=admin12345
